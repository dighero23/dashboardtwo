# ── Finnhub (free tier) ──────────────────────────────────────────────────────
# Get your free API key at https://finnhub.io
# Used for next earnings dates per ticker, cached daily.
# If not set, earnings column will show "—" for all tickers.
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Cron security (optional but recommended) ──────────────────────────────────
# A secret token to protect /api/check-alerts from unauthorized calls.
# Set the same value in cron-job.org as: Authorization: Bearer <secret>
# Generate one with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ── Supabase (Phase 1c) ───────────────────────────────────────────────────────
# Add these when connecting Supabase in Phase 1c.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── VAPID / Web Push (Phase 1d) ───────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:your@email.com
